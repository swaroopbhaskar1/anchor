# Server-side OpenAI API key used by /api/session, /api/mirror, /api/plan, /api/fear, and embedding scripts.
OPENAI_API_KEY=

# Pinecone API key used by RAG routes and vector seeding/check scripts.
PINECONE_API_KEY=

# Pinecone index name that contains the guidelines, wisdom, and patient-docs namespaces.
PINECONE_INDEX_NAME=

# Llama Cloud API key used by /api/ingest to parse uploaded pathology PDFs.
LLAMA_CLOUD_API_KEY=

# Server-side Appwrite endpoint for node-appwrite admin writes.
APPWRITE_ENDPOINT=

# Server-side Appwrite project id for node-appwrite admin writes.
APPWRITE_PROJECT_ID=

# Server-side Appwrite API key with database permissions for fear/artifact writes and setup scripts.
APPWRITE_API_KEY=

# Server-side Appwrite database id used by API routes and setup scripts.
APPWRITE_DATABASE_ID=

# Browser-safe Appwrite endpoint used by the client Appwrite SDK.
NEXT_PUBLIC_APPWRITE_ENDPOINT=

# Browser-safe Appwrite project id used by the client Appwrite SDK.
NEXT_PUBLIC_APPWRITE_PROJECT_ID=

# Browser-safe Appwrite database id used by the client Appwrite SDK.
NEXT_PUBLIC_APPWRITE_DATABASE_ID=

# Appwrite collection id for caregiver profiles.
NEXT_PUBLIC_APPWRITE_PROFILES_COLLECTION_ID=

# Appwrite collection id for private journal entries.
NEXT_PUBLIC_APPWRITE_JOURNAL_COLLECTION_ID=

# Optional browser-exposed Firecrawl key for the legacy scrapeWebsite Realtime tool.
NEXT_PUBLIC_FIRECRAWL_API_KEY=
